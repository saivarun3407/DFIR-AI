#!/usr/bin/env bash
# MemoryHound CLI — install, run, verify autonomous DFIR triage cases.
#
# Subcommands:
#   mh doctor              health check — Python, Claude Code, deps, keys, perms
#   mh init                first-time setup — venv, deps, signing keys
#   mh run    <case-id>    run Claude Code triage on cases/<case-id>/input/
#   mh verify <case-id>    verify chain + signature for a completed case
#   mh status              recent cases + their phase
#   mh tools               list MCP tools the agent can call
#   mh check               quick env probe (subset of doctor, exit code)
#
# Works with both Claude subscription (claude /login) and ANTHROPIC_API_KEY.
set -euo pipefail

MH_HOME="${MH_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
MH_VENV="${MH_VENV:-${MH_HOME}/.venv}"
MH_PY="${MH_VENV}/bin/python"
MH_KEYS_DIR="${MH_HOME}/keys"
MH_CASES_DIR="${MH_HOME}/cases"

GREEN=$'\e[0;32m'
RED=$'\e[0;31m'
YELLOW=$'\e[0;33m'
BOLD=$'\e[1m'
NC=$'\e[0m'

ok()     { echo -e "${GREEN}✓${NC} $*"; }
warn()   { echo -e "${YELLOW}!${NC} $*"; }
fail()   { echo -e "${RED}✗${NC} $*"; }
info()   { echo -e "${BOLD}»${NC} $*"; }

# ─── claude wrapper ──────────────────────────────────────────────────────────

# claude_run: pipe a prompt to claude in non-interactive autonomous mode.
# We pass the prompt via stdin because --allowedTools is variadic and would
# consume the prompt as another tool name if passed positionally.
claude_run() {
    local prompt="$1"
    local allowed="mcp__protocol_sift__hash,mcp__protocol_sift__chain_append,mcp__protocol_sift__chain_verify,mcp__protocol_sift__chain_acknowledge_gap,mcp__protocol_sift__finding_record,mcp__protocol_sift__os_detect,mcp__protocol_sift__magic_check,mcp__protocol_sift__win_registry_get,mcp__protocol_sift__win_prefetch_parse,mcp__protocol_sift__win_evtx_query,mcp__protocol_sift__win_lnk_parse,mcp__protocol_sift__mac_plist_get,mcp__protocol_sift__mac_knowledgec_query,Read,Glob,Grep,TodoWrite"
    if [[ "${MH_CLAUDE_DEBUG:-0}" == "1" ]]; then
        printf '%s' "$prompt" | claude -p -d --allowedTools "$allowed"
    else
        printf '%s' "$prompt" | claude -p --allowedTools "$allowed"
    fi
}

# ─── doctor ──────────────────────────────────────────────────────────────────

cmd_doctor() {
    local errors=0
    info "MemoryHound doctor — checking environment"
    echo ""

    if command -v python3.13 >/dev/null 2>&1; then
        ok "Python 3.13 available: $(command -v python3.13)"
    elif command -v python3.12 >/dev/null 2>&1; then
        ok "Python 3.12 available: $(command -v python3.12)"
    elif command -v python3.11 >/dev/null 2>&1; then
        ok "Python 3.11 available: $(command -v python3.11)"
    else
        fail "No Python 3.11+ found. Install: brew install python@3.12 (macOS) or apt install python3.12 (Ubuntu)"
        errors=$((errors + 1))
    fi

    if [[ -x "$MH_PY" ]]; then
        ok "venv at $MH_VENV ($("$MH_PY" --version 2>&1))"
    else
        warn "venv not yet created — run: mh init"
    fi

    if [[ -x "$MH_PY" ]]; then
        if "$MH_PY" -c "import protocol_sift_mcp" 2>/dev/null; then
            ok "protocol_sift_mcp installed in venv"
        else
            warn "protocol_sift_mcp not installed — run: mh init"
        fi
        if "$MH_PY" -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey" 2>/dev/null; then
            ok "cryptography (signing) ready"
        else
            warn "cryptography missing — run: mh init"
        fi
        if "$MH_PY" -c "import Registry, Evtx, pylnk3, windowsprefetch" 2>/dev/null; then
            ok "Windows forensic libs ready (Registry, Evtx, pylnk3, windowsprefetch)"
        else
            warn "Windows forensic libs missing — run: mh init --with-forensics (optional, only needed for real evidence)"
        fi
    fi

    if command -v claude >/dev/null 2>&1; then
        ok "Claude Code installed: $(command -v claude)"
        if claude --version 2>/dev/null | head -1; then :; fi
    else
        fail "Claude Code not installed. Install: https://docs.claude.com/en/docs/claude-code/quickstart"
        errors=$((errors + 1))
    fi

    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        ok "ANTHROPIC_API_KEY set (auth mode: API key)"
    elif [[ -d "$HOME/.claude" ]]; then
        ok "~/.claude/ exists (auth mode: Pro/Max login likely active — run 'claude /status' to confirm)"
    else
        warn "No ANTHROPIC_API_KEY env var and no ~/.claude/ — auth not configured"
        warn "    EITHER  export ANTHROPIC_API_KEY=sk-ant-...   OR   claude /login"
    fi

    if [[ -f "${MH_KEYS_DIR}/ed25519.priv" ]]; then
        ok "Signing keypair exists at ${MH_KEYS_DIR}/"
        if [[ "$(stat -f '%p' "${MH_KEYS_DIR}/ed25519.priv" 2>/dev/null || stat -c '%a' "${MH_KEYS_DIR}/ed25519.priv" 2>/dev/null)" =~ 600$ ]]; then
            ok "    private key permissions are 0600"
        else
            warn "    private key NOT 0600 — run: chmod 600 ${MH_KEYS_DIR}/ed25519.priv"
        fi
    else
        warn "No signing keypair — run: mh init"
    fi

    if [[ -f "${MH_HOME}/.claude/settings.json" ]]; then
        ok ".claude/settings.json present (Claude Code will pick up MCP + hooks here)"
    else
        fail ".claude/settings.json missing — repo seems incomplete"
        errors=$((errors + 1))
    fi

    if [[ -x "${MH_HOME}/bin/mh-mcp-server" ]]; then
        ok "MCP server launcher executable"
    else
        warn "bin/mh-mcp-server not executable — run: chmod +x bin/mh-mcp-server"
    fi

    echo ""
    if [[ $errors -eq 0 ]]; then
        ok "All critical checks passed."
        info "Next: drop evidence into cases/<id>/input/, then 'mh run <id>'"
        return 0
    else
        fail "$errors critical issue(s). Fix above before running cases."
        return 1
    fi
}

# ─── init ────────────────────────────────────────────────────────────────────

cmd_init() {
    local with_forensics=0
    for arg in "$@"; do
        case "$arg" in
            --with-forensics) with_forensics=1 ;;
            -h|--help) echo "Usage: mh init [--with-forensics]"; return 0 ;;
        esac
    done

    info "MemoryHound init — creating venv + installing deps"

    local PY=""
    for cand in python3.13 python3.12 python3.11; do
        if command -v "$cand" >/dev/null 2>&1; then
            PY="$cand"; break
        fi
    done
    if [[ -z "$PY" ]]; then
        fail "Python 3.11+ required. Install with brew or apt."
        return 1
    fi
    info "Using $PY ($(command -v "$PY"))"

    if [[ ! -x "$MH_PY" ]]; then
        info "Creating venv at $MH_VENV"
        "$PY" -m venv "$MH_VENV"
    fi

    info "Installing protocol_sift_mcp (core + dev)"
    "$MH_PY" -m pip install --quiet --upgrade pip
    "$MH_PY" -m pip install --quiet -e "${MH_HOME}/mcp-server[dev]"

    if [[ $with_forensics -eq 1 ]]; then
        info "Installing forensics extras (heavy: volatility3, python-evtx, etc)"
        "$MH_PY" -m pip install --quiet -e "${MH_HOME}/mcp-server[dev,forensics]"
    fi

    if [[ ! -f "${MH_KEYS_DIR}/ed25519.priv" ]]; then
        info "Generating ed25519 signing keypair"
        mkdir -p "$MH_KEYS_DIR"
        "$MH_PY" -m protocol_sift_mcp.tools.evidence keygen --out-dir "$MH_KEYS_DIR"
        chmod 600 "${MH_KEYS_DIR}/ed25519.priv"
        ok "Keypair at ${MH_KEYS_DIR}/"
    else
        ok "Keypair already exists at ${MH_KEYS_DIR}/"
    fi

    chmod +x "${MH_HOME}"/bin/mh "${MH_HOME}"/bin/mh-mcp-server "${MH_HOME}"/.claude/hooks/*.sh 2>/dev/null || true

    mkdir -p "$MH_CASES_DIR"

    info "Running test suite to verify install"
    if PYTHONPATH="${MH_HOME}/mcp-server/src" "$MH_PY" -m pytest "${MH_HOME}/mcp-server/tests" -q --no-cov 2>&1 | tail -5; then
        ok "Tests passing"
    else
        warn "Tests did not all pass — check above"
    fi

    echo ""
    ok "Init complete."
    info "Next: 'mh doctor' to confirm full env, then 'mh run <case-id>'"
}

# ─── run ─────────────────────────────────────────────────────────────────────

cmd_run() {
    local case_id="${1:-}"
    if [[ -z "$case_id" ]]; then
        fail "Usage: mh run <case-id>"
        echo "       Evidence must live at cases/<case-id>/input/"
        return 2
    fi

    local case_dir="${MH_CASES_DIR}/${case_id}"
    local input_dir="${case_dir}/input"
    local output_dir="${case_dir}/output"

    if [[ ! -d "$input_dir" ]]; then
        fail "No evidence at ${input_dir}"
        info "Drop files into ${input_dir}/ then re-run."
        return 2
    fi

    if [[ -z "$(ls -A "$input_dir" 2>/dev/null)" ]]; then
        warn "${input_dir} is empty"
        return 2
    fi

    mkdir -p "$output_dir"

    if [[ -z "${ANTHROPIC_API_KEY:-}" ]] && [[ ! -d "$HOME/.claude" ]]; then
        fail "No Claude auth. Set ANTHROPIC_API_KEY or run: claude /login"
        return 1
    fi

    if ! command -v claude >/dev/null 2>&1; then
        fail "claude CLI not installed"
        return 1
    fi

    info "Case: ${case_id}"
    info "Evidence: ${input_dir}"
    info "Output:   ${output_dir}"
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        info "Auth: API key"
    else
        info "Auth: Claude subscription (Pro/Max)"
    fi

    export CASE_ID="$case_id"
    export EVIDENCE_PATH="$input_dir"
    export OUTPUT_PATH="$output_dir"
    export MH_HOME

    info "Launching Claude Code with triage-orchestrator skill"
    cd "$MH_HOME"
    claude_run "Use the triage-orchestrator skill to autonomously triage every artifact under ${input_dir}. Route to the correct OS specialist. Pin every finding. Acknowledge gaps explicitly. Stop when triage is complete. Write findings.json, narrative.md, and accuracy-report.md to ${output_dir}."
}

# ─── serve (local web viewer) ────────────────────────────────────────────────

cmd_serve() {
    local port="${MH_SERVE_PORT:-8765}"
    local host="127.0.0.1"
    for arg in "$@"; do
        case "$arg" in
            --port=*) port="${arg#--port=}" ;;
            --host=*) host="${arg#--host=}" ;;
            -h|--help) echo "Usage: mh serve [--port=8765] [--host=127.0.0.1]"; return 0 ;;
        esac
    done

    if ! "$MH_PY" -c "import markdown" 2>/dev/null; then
        info "Installing markdown viewer dep into venv (one-time)…"
        "$MH_PY" -m pip install --quiet markdown pygments
    fi

    info "Starting MemoryHound viewer on http://${host}:${port}/"
    info "Press Ctrl-C to stop."
    echo ""
    if command -v open >/dev/null 2>&1; then
        ( sleep 1 && open "http://${host}:${port}/" ) &
    elif command -v xdg-open >/dev/null 2>&1; then
        ( sleep 1 && xdg-open "http://${host}:${port}/" ) &
    fi
    "$MH_PY" "${MH_HOME}/scripts/serve.py" --host "$host" --port "$port"
}

# ─── report (plain-English summary, no LLM, no tokens) ──────────────────────

cmd_report() {
    local case_id="${1:-}"
    if [[ -z "$case_id" ]]; then
        fail "Usage: mh report <case-id>"
        return 2
    fi
    local case_dir="${MH_CASES_DIR}/${case_id}"
    if [[ ! -d "$case_dir/output" ]]; then
        fail "No output dir at ${case_dir}/output — run mh run first"
        return 1
    fi
    "$MH_PY" "${MH_HOME}/scripts/plain-summary.py" "$case_dir"
    local out="${case_dir}/output/summary.md"
    echo ""
    info "Plain-English summary at ${out}"
    echo ""
    head -40 "$out"
}

# ─── verify ──────────────────────────────────────────────────────────────────

cmd_verify() {
    local case_id="${1:-}"
    if [[ -z "$case_id" ]]; then
        fail "Usage: mh verify <case-id>"
        return 2
    fi

    local output_dir="${MH_CASES_DIR}/${case_id}/output"
    local chain="${output_dir}/chain-of-custody.jsonl"
    local findings="${output_dir}/findings.json"
    local attestation="${output_dir}/case-${case_id}.attestation.json"

    if [[ ! -f "$chain" ]]; then
        fail "No chain log at ${chain}"
        return 1
    fi

    info "Verifying chain of custody"
    if "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_verify --chain "$chain"; then
        ok "Chain valid"
    else
        fail "Chain INVALID — tampering detected"
        return 1
    fi

    if [[ -f "$findings" ]]; then
        local count
        count=$("$MH_PY" -c "import json; print(len(json.load(open('$findings'))))")
        ok "${count} finding(s) recorded"
    fi

    if [[ -f "$attestation" ]]; then
        ok "Signed attestation present at ${attestation}"
        info "Verify signature with: mh-verify-attestation ${attestation} keys/ed25519.pub"
    else
        warn "No attestation file (case may not have completed)"
    fi
}

# ─── status ──────────────────────────────────────────────────────────────────

cmd_status() {
    if [[ ! -d "$MH_CASES_DIR" ]]; then
        info "No cases yet. mh run <id> creates one."
        return 0
    fi

    info "Cases:"
    for case_dir in "$MH_CASES_DIR"/*/; do
        [[ ! -d "$case_dir" ]] && continue
        local id
        id=$(basename "$case_dir")
        local phase="empty"
        if [[ -f "${case_dir}/output/case-${id}.attestation.json" ]]; then
            phase="${GREEN}signed${NC}"
        elif [[ -f "${case_dir}/output/findings.json" ]]; then
            phase="${YELLOW}finished (unsigned)${NC}"
        elif [[ -f "${case_dir}/output/chain-of-custody.jsonl" ]]; then
            phase="${YELLOW}in-progress${NC}"
        elif [[ -d "${case_dir}/input" ]] && [[ -n "$(ls -A "${case_dir}/input" 2>/dev/null)" ]]; then
            phase="staged"
        fi
        echo -e "  ${id}  →  ${phase}"
    done
}

# ─── tools ───────────────────────────────────────────────────────────────────

cmd_tools() {
    info "MCP tools exposed by protocol_sift:"
    cat <<'EOF'
  Trust stack:
    hash                       — sha256 + sha1 + size
    chain_append               — append to hash-chained audit log
    chain_verify               — recompute chain, detect tampering
    chain_acknowledge_gap      — explicit "I don't know" entry
    finding_record             — register finding (rejects un-pinned)

  Cross-OS routing:
    os_detect                  — magic-byte + dir-marker OS classification
    magic_check                — first-16-bytes signature probe

  Windows triage:
    win_registry_get           — read registry key (NTUSER, SOFTWARE, etc)
    win_prefetch_parse         — parse .pf for execution proof
    win_evtx_query             — filter EVTX by EID + time range
    win_lnk_parse              — parse .lnk for target + drive_serial

  macOS triage (W3 stub):
    mac_apfs_inspect, mac_plist_get, mac_tracev3_query,
    mac_knowledgec_query, mac_spotlight_query

  Linux triage (W4 stub):
    linux_journal_query, linux_audit_query, linux_history_parse,
    linux_systemd_units, linux_cron_parse

  Memory (W2-W4 stub):
    memory_volatility          — Volatility 3 plugin invocation
EOF
}

# ─── check (quick env probe with exit code) ─────────────────────────────────

cmd_check() {
    if cmd_doctor >/dev/null 2>&1; then
        ok "OK"
        return 0
    else
        fail "FAIL — run 'mh doctor' for details"
        return 1
    fi
}

# ─── self-collect ────────────────────────────────────────────────────────────

cmd_self_collect() {
    local dest="${1:-${MH_CASES_DIR}/_self/input}"
    "${MH_HOME}/scripts/self-collect.sh" "$dest"
}

# ─── demo ────────────────────────────────────────────────────────────────────

cmd_demo() {
    local autonomous=0
    for arg in "$@"; do
        case "$arg" in
            --autonomous|--auto) autonomous=1 ;;
            -h|--help) echo "Usage: mh demo [--autonomous]"; return 0 ;;
        esac
    done

    if [[ $autonomous -eq 1 ]]; then
        info "MemoryHound autonomous demo — self-collect + Claude Code triage."
        info "Costs tokens. Needs claude /login OR ANTHROPIC_API_KEY."
    else
        info "MemoryHound real-data demo — collects safe artifacts from THIS host,"
        info "runs them through MemoryHound's tools, proves chain tamper-detection."
        info "No network, no Claude tokens. All read-only on host."
    fi
    echo ""

    local demo_dir="${MH_CASES_DIR}/_demo"
    rm -rf "$demo_dir"
    mkdir -p "${demo_dir}/input" "${demo_dir}/output"

    info "Step 1: self-collect host artifacts"
    "${MH_HOME}/scripts/self-collect.sh" "${demo_dir}/input" 2>&1 | sed 's/^/    /'

    local chain="${demo_dir}/output/chain.jsonl"
    export EVIDENCE_PATH="${demo_dir}/input"
    export OUTPUT_PATH="${demo_dir}/output"

    echo ""
    info "Step 2: chain_init — write genesis entry to chain.jsonl"
    "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_init \
        --output "$chain" \
        --case-id "demo" \
        --evidence-path "${demo_dir}/input" \
        --agent-version "memoryhound@0.1.0" \
        --model "claude-opus-4-7" >/dev/null
    ok "    chain initialized"

    echo ""
    info "Step 3: ingest each real artifact (compute sha256 + sha1 of actual bytes)"
    local ingested=0
    while IFS= read -r f; do
        "$MH_PY" -m protocol_sift_mcp.tools.evidence ingest --chain "$chain" --artifact "$f" >/dev/null
        ingested=$((ingested + 1))
    done < <(find "${demo_dir}/input" -type f)
    ok "    $ingested artifacts ingested"

    echo ""
    info "Step 4: classify each artifact with os_detect + run matching parser"
    local findings=0
    while IFS= read -r f; do
        local rel="${f#${demo_dir}/input/}"
        local classification
        classification=$(PYTHONPATH="${MH_HOME}/mcp-server/src" "$MH_PY" -c "
from protocol_sift_mcp.tools import parse, macos
import json, sys
path = '$f'
det = parse.os_detect(path)
out = {'rel': '$rel', 'os': det['os'], 'class': det['evidence_class'], 'conf': det['confidence']}
if det['evidence_class'] == 'plist':
    try:
        r = macos.mac_plist_get(path)
        out['format'] = r['format']
        out['root_keys_count'] = len(r['root_keys'])
        out['top3_keys'] = r['root_keys'][:3]
    except Exception as e:
        out['parse_error'] = str(e)[:80]
print(json.dumps(out))
" 2>&1) || classification="{}"
        echo "    [$rel]"
        echo "        $classification" | sed 's/^/        /'

        "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_append \
            --chain "$chain" \
            --event "tool_call" \
            --data "{\"tool\":\"os_detect+parse\",\"artifact\":\"$rel\",\"result\":$classification}" >/dev/null
        findings=$((findings + 1))
    done < <(find "${demo_dir}/input" -type f)
    ok "    $findings classifications recorded to chain"

    echo ""
    info "Step 5: verify chain integrity"
    if "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_verify --chain "$chain" >/dev/null; then
        ok "    ✓ chain valid"
    else
        fail "    chain reported invalid — this is a bug"
        return 1
    fi

    echo ""
    info "Step 6: TAMPER one entry (silently change a finding's classification)"
    cp "$chain" "${chain}.bak"
    sed -i.tmp 's/"os":"macos"/"os":"linux"/' "$chain"
    rm -f "${chain}.tmp"
    ok "    swapped one 'macos' classification to 'linux'"

    echo ""
    info "Step 7: re-verify — chain should DETECT the tamper"
    if "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_verify --chain "$chain" 2>&1 | head -1; then
        fail "    chain reported valid AFTER tamper — this is a bug"
        return 1
    else
        ok "    ✗ chain INVALID — tamper detected (as expected)"
    fi

    echo ""
    info "Step 8: restore + re-verify (chain valid again)"
    mv "${chain}.bak" "$chain"
    if "$MH_PY" -m protocol_sift_mcp.tools.evidence chain_verify --chain "$chain" >/dev/null; then
        ok "    ✓ chain valid again"
    fi

    echo ""
    ok "Local demo complete."
    echo ""
    info "What just happened:"
    echo "    1. Collected $ingested real DFIR artifacts from your Mac (read-only)"
    echo "    2. Ingested every byte into a tamper-evident hash chain"
    echo "    3. Ran os_detect + matching parser on each → real findings extracted"
    echo "    4. Verified chain → green"
    echo "    5. Edited one entry post-hoc → chain detected it"
    echo "    6. Restored → chain green again"
    echo ""
    info "Artifacts saved to:"
    echo "    ${demo_dir}/input/    — read-only host artifact copies"
    echo "    ${demo_dir}/output/chain.jsonl  — the audit log (tamper-evident)"

    if [[ $autonomous -eq 1 ]]; then
        echo ""
        info "════ AUTONOMOUS PHASE ═══════════════════════════════════════"
        info "Now spawning Claude Code with triage-orchestrator skill."
        info "Claude will autonomously call os_detect + mac_plist_get on each"
        info "artifact, pin every finding, and produce a signed report."
        echo ""

        if [[ -z "${ANTHROPIC_API_KEY:-}" ]] && [[ ! -d "$HOME/.claude" ]]; then
            fail "No Claude auth configured. Run one of:"
            echo "    claude /login                          # Pro/Max subscription"
            echo "    export ANTHROPIC_API_KEY=sk-ant-...    # API key"
            return 1
        fi

        if ! command -v claude >/dev/null 2>&1; then
            fail "claude CLI not on PATH. See docs.claude.com/en/docs/claude-code/quickstart"
            return 1
        fi

        export CASE_ID="_demo"
        export EVIDENCE_PATH="${demo_dir}/input"
        export OUTPUT_PATH="${demo_dir}/output"

        info "Launching Claude Code (this will take ~2-5 min and consume tokens)…"
        cd "$MH_HOME"

        local prompt
        prompt="$(cat <<'EOP'
Use the triage-orchestrator skill to autonomously triage every artifact under
the EVIDENCE_PATH directory. For each artifact:

1. Call os_detect to classify it.
2. If macOS plist, call mac_plist_get to extract structured contents.
3. Record findings with finding_record, every claim pinned to specific bytes
   from the artifact (use the raw_excerpt field of the pin).
4. When uncertain, call chain_acknowledge_gap rather than guessing.
5. Stop when every artifact has been triaged.

Final output should land in OUTPUT_PATH:
  - findings.json (pinned findings)
  - narrative.md (investigator-readable report)
  - accuracy-report.md (FP/FN/uncertain tally)

The Stop hook will verify the chain and sign the attestation.
EOP
)"

        if claude_run "$prompt"; then
            ok "Autonomous triage complete."
            echo ""
            info "Verifying chain + signature post-run:"
            cmd_verify "_demo"
            echo ""
            info "Generating plain-English summary (no LLM, deterministic)…"
            "$MH_PY" "${MH_HOME}/scripts/plain-summary.py" "$demo_dir" >/dev/null
            ok "Plain-English summary at ${demo_dir}/output/summary.md"
        else
            fail "Claude Code exited non-zero. Check above for errors."
            return 1
        fi
    fi
}

# ─── help ────────────────────────────────────────────────────────────────────

cmd_help() {
    cat <<EOF
${BOLD}MemoryHound — autonomous DFIR triage with Claude Code${NC}

${BOLD}USAGE${NC}
    mh <command> [args]

${BOLD}COMMANDS${NC}
    init [--with-forensics]   First-time setup: venv, deps, ed25519 keys.
                              --with-forensics adds heavy libs (Volatility, etc.)
    doctor                    Health check across env, deps, auth, keys.
    self-collect [DEST]       Copy safe DFIR artifacts from this host into DEST
                              (default cases/_self/input). No root, no creds.
    demo [--autonomous]       Real-data showcase: self-collect + parse + chain
                              tamper-detect, all on YOUR machine, no tokens.
                              --autonomous adds a Claude Code triage run after
                              the local demo (consumes tokens).
    run <case-id>             Run Claude Code triage on cases/<id>/input/.
    report <case-id>          Generate plain-English summary from findings
                              (deterministic, no LLM, no tokens).
    serve [--port=N]          Local web viewer for cases (markdown rendered,
                              chain log pretty-printed). Default port 8765.
    verify <case-id>          Verify chain-of-custody integrity for a case.
    status                    List cases + their phase.
    tools                     List MCP tools the agent can call.
    check                     Quick env probe (exit 0/1).
    help                      Show this.

${BOLD}WORKFLOW${NC}
    1. mh init                                    # one-time setup
    2. claude /login   OR   export ANTHROPIC_API_KEY=sk-ant-...
    3. mkdir -p cases/case-001/input
       cp /path/to/evidence/* cases/case-001/input/
    4. mh run case-001                            # autonomous triage
    5. mh verify case-001                         # validate chain + signature

${BOLD}DOCS${NC}
    docs/architecture.md      — full design
    docs/usage.md             — detailed usage
    docs/development.md       — pre-commit + CI workflow

${BOLD}HOMEPAGE${NC}
    https://github.com/saivarun3407/DFIR-AI
EOF
}

# ─── dispatch ────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        init)         cmd_init "$@" ;;
        doctor)       cmd_doctor "$@" ;;
        demo)         cmd_demo "$@" ;;
        self-collect) cmd_self_collect "$@" ;;
        run)          cmd_run "$@" ;;
        report)       cmd_report "$@" ;;
        serve)        cmd_serve "$@" ;;
        verify)       cmd_verify "$@" ;;
        status)       cmd_status "$@" ;;
        tools)        cmd_tools "$@" ;;
        check)        cmd_check "$@" ;;
        help|-h|--help) cmd_help ;;
        *)            fail "Unknown command: $cmd"; cmd_help; return 2 ;;
    esac
}

main "$@"
